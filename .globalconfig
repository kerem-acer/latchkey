# Global analyzer configuration
# This file configures analyzer severity for all file types including Razor.
# .editorconfig rules take precedence for .cs files.
is_global = true

# Baseline: treat all analyzer diagnostics as errors
dotnet_analyzer_diagnostic.severity = error

# Compiler null-safety warnings (not covered by dotnet_analyzer_diagnostic baseline)

# Tier 1 — direct NullReferenceException risk
dotnet_diagnostic.CS8597.severity = error # Thrown value may be null
dotnet_diagnostic.CS8600.severity = error # Converting null literal or possible null value to non-nullable type
dotnet_diagnostic.CS8601.severity = error # Possible null reference assignment
dotnet_diagnostic.CS8602.severity = error # Dereference of a possibly null reference
dotnet_diagnostic.CS8603.severity = error # Possible null reference return
dotnet_diagnostic.CS8604.severity = error # Possible null reference argument
dotnet_diagnostic.CS8605.severity = error # Unboxing a possibly null value
dotnet_diagnostic.CS8625.severity = error # Cannot convert null literal to non-nullable reference type
dotnet_diagnostic.CS8629.severity = error # Nullable value type may be null
dotnet_diagnostic.CS8670.severity = error # Object/collection initializer implicitly dereferences possibly null member

# Tier 2 — API contract nullability mismatches
dotnet_diagnostic.CS8619.severity = error # Nullability in value doesn't match target type
dotnet_diagnostic.CS8620.severity = error # Argument nullability mismatch for parameter
dotnet_diagnostic.CS8624.severity = error # Out argument nullability mismatch
dotnet_diagnostic.CS8631.severity = error # Type argument nullability doesn't match constraint
dotnet_diagnostic.CS8634.severity = error # Type argument nullability doesn't match class constraint
dotnet_diagnostic.CS8714.severity = error # Type argument nullability doesn't match notnull constraint

# Tier 3 — inheritance / interface signature nullability mismatches
dotnet_diagnostic.CS8608.severity = error
dotnet_diagnostic.CS8609.severity = error
dotnet_diagnostic.CS8610.severity = error
dotnet_diagnostic.CS8611.severity = error
