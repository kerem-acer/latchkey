# Tier 4 — constructor / parameter initialization
dotnet_diagnostic.CS8618.severity = error # Non-nullable member not initialized in constructor
dotnet_diagnostic.CS8762.severity = error # Parameter must have non-null value when exiting

# Tier 5 — attribute contract violations
dotnet_diagnostic.CS8607.severity = error
dotnet_diagnostic.CS8763.severity = error # [DoesNotReturn] method should not return
dotnet_diagnostic.CS8770.severity = error
dotnet_diagnostic.CS8774.severity = error
dotnet_diagnostic.CS8775.severity = error
dotnet_diagnostic.CS8776.severity = error
dotnet_diagnostic.CS8777.severity = error
dotnet_diagnostic.CS8824.severity = error
dotnet_diagnostic.CS8825.severity = error

# Tier 6 — switch exhaustiveness on null
dotnet_diagnostic.CS8655.severity = error
dotnet_diagnostic.CS8847.severity = error

dotnet_diagnostic.CS8509.severity = suggestion

