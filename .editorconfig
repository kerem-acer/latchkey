# Top-most EditorConfig file
root = true

# All files
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# C# files
[*.cs]

csharp_style_namespace_declarations = file_scoped:warning

# Treat all warnings as errors
dotnet_analyzer_diagnostic.severity = error

# New line preferences
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true
csharp_align_multiline_array_and_object_initializer = false

# Property and block style preferences
csharp_style_expression_bodied_properties = true:warning
csharp_style_expression_bodied_accessors = true:warning
csharp_style_expression_bodied_methods = true:silent
csharp_style_expression_bodied_operators = true:silent
csharp_style_expression_bodied_local_functions = true:silent
csharp_style_expression_bodied_constructors = false:silent

# Indentation preferences
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents_when_block = true

# Space preferences
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_before_colon_in_inheritance_clause = true
csharp_space_after_colon_in_inheritance_clause = true
csharp_space_around_binary_operators = before_and_after
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false
csharp_space_between_method_call_name_and_opening_parenthesis = false
csharp_space_between_method_call_empty_parameter_list_parentheses = false

# Modifier preferences
csharp_preferred_modifier_order = public, private, protected, internal, static, extern, new, virtual, abstract, sealed, override, readonly, unsafe, volatile, async:warning

# var preferences (suggest var, but don't enforce — explicit types are allowed)
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion
dotnet_diagnostic.IDE0007.severity = suggestion

# Expression-level preferences
dotnet_style_object_initializer = true:warning
dotnet_style_collection_initializer = true:warning
dotnet_style_explicit_tuple_names = true:warning
dotnet_style_coalesce_expression = true:warning
dotnet_style_null_propagation = true:warning
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:warning
dotnet_style_prefer_inferred_tuple_names = true:warning
dotnet_style_prefer_inferred_anonymous_type_member_names = true:warning
dotnet_style_prefer_auto_properties = true:warning
dotnet_style_prefer_conditional_expression_over_assignment = true:warning
dotnet_style_prefer_conditional_expression_over_return = true:warning
dotnet_style_require_accessibility_modifiers = omit_if_default:suggestion
csharp_prefer_simple_default_expression = true:warning
csharp_style_prefer_primary_constructors = false
csharp_style_pattern_matching_over_is_with_cast_check = true:warning

# Single line preferences
csharp_preserve_single_line_blocks = true
csharp_preserve_single_line_statements = false

# === ReSharper CleanupCode settings ===
# These settings control `jb cleanupcode` behavior to prevent breaking changes.

# --- Inspection quick-fix suppressions ---
# CRITICAL: Do NOT remove private setters (breaks MongoDB deserialization)
resharper_auto_property_can_be_made_get_only_global_highlighting = none
resharper_auto_property_can_be_made_get_only_local_highlighting = none

# Do NOT add readonly to fields automatically
resharper_field_can_be_made_read_only_global_highlighting = none
resharper_field_can_be_made_read_only_local_highlighting = none

# Do NOT remove named arguments
resharper_redundant_argument_default_value_highlighting = none
resharper_arrange_named_expression_highlighting = none

# Do NOT remove redundant parentheses
resharper_redundant_parentheses_highlighting = none
resharper_arrange_redundant_parentheses_highlighting = none
resharper_parentheses_redundancy_style = keep_all

# --- Named arguments: keep existing, do not remove ---
resharper_csharp_arguments_literal = positional
resharper_csharp_arguments_string_literal = positional
resharper_csharp_arguments_named = positional
resharper_csharp_arguments_anonymous_function = positional
resharper_csharp_arguments_other = positional
resharper_csharp_arguments_skip_single = true

# --- Extra spaces ---
resharper_csharp_extra_spaces = remove_all

# --- Spacing around operators ---
resharper_csharp_space_around_assignment_op = true
resharper_csharp_space_around_logical_op = true
resharper_csharp_space_around_equality_op = true
resharper_csharp_space_around_relational_op = true
resharper_csharp_space_around_bitwise_op = true
resharper_csharp_space_around_additive_op = true
resharper_csharp_space_around_multiplicative_op = true
resharper_csharp_space_around_shift_op = true
resharper_csharp_space_around_nullcoalescing_op = true
resharper_csharp_space_around_ternary_operator = true
resharper_csharp_space_after_unary_operator = false
resharper_csharp_space_after_logical_not_op = false
resharper_csharp_space_after_unary_minus_op = false
resharper_csharp_space_after_unary_plus_op = false
resharper_csharp_space_within_type_parameter_angles = false
resharper_csharp_space_within_type_argument_angles = false
resharper_csharp_space_before_type_parameter_angle = false
resharper_csharp_space_before_type_argument_angle = false
resharper_csharp_space_within_empty_braces = true
resharper_csharp_space_between_typecast_parentheses = false
resharper_csharp_space_between_parentheses_of_control_flow_statements = false
resharper_csharp_space_before_open_square_brackets = false
resharper_csharp_space_between_square_brackets = false
resharper_csharp_space_between_empty_square_brackets = false
resharper_csharp_space_before_typeof_parentheses = false
resharper_csharp_space_before_default_parentheses = false
resharper_csharp_space_before_sizeof_parentheses = false
resharper_csharp_space_before_nameof_parentheses = false
resharper_csharp_space_before_semicolon_in_for_statement = false
resharper_csharp_space_after_semicolon_in_for_statement = true
resharper_csharp_space_before_comma = false
resharper_csharp_space_after_comma = true
resharper_csharp_space_after_cast = false
resharper_csharp_space_after_keywords_in_control_flow_statements = true
resharper_csharp_space_between_method_call_parameter_list_parentheses = false
resharper_csharp_space_between_method_call_empty_parameter_list_parentheses = false
resharper_csharp_space_between_method_call_name_and_opening_parenthesis = false
resharper_csharp_space_between_method_declaration_parameter_list_parentheses = false
resharper_csharp_space_between_method_declaration_empty_parameter_list_parentheses = false
resharper_csharp_space_before_colon_in_inheritance_clause = true
resharper_csharp_space_after_colon_in_inheritance_clause = true
resharper_csharp_space_around_binary_operator = true
resharper_csharp_space_after_dot = false
resharper_csharp_space_before_colon_in_case = false
resharper_csharp_space_between_method_declaration_name_and_open_parenthesis = false

# --- Braces layout ---
resharper_csharp_brace_style = next_line
resharper_csharp_accessor_declaration_braces = next_line
resharper_csharp_accessor_owner_declaration_braces = next_line
resharper_csharp_anonymous_method_declaration_braces = next_line
resharper_csharp_case_block_braces = next_line_shifted_2
resharper_csharp_invocable_declaration_braces = next_line
resharper_csharp_initializer_braces = next_line
resharper_csharp_empty_block_style = together
resharper_csharp_allow_comment_after_lbrace = false
resharper_csharp_indent_inside_namespace = true

# --- Braces: always required (must match editorconfig) ---
resharper_csharp_braces_for_ifelse = required
resharper_csharp_braces_for_for = required
resharper_csharp_braces_for_foreach = required
resharper_csharp_braces_for_while = required
resharper_csharp_braces_for_dowhile = required
resharper_csharp_braces_for_using = required
resharper_csharp_braces_for_lock = required
resharper_csharp_braces_for_fixed = required
resharper_csharp_braces_redundant = false

# --- Expression body preferences: keep existing style ---
resharper_csharp_method_or_operator_body = expression_body
resharper_csharp_local_function_body = expression_body
resharper_csharp_constructor_or_destructor_body = block_body
resharper_csharp_accessor_owner_body = expression_body

# --- Modifier visibility ---
resharper_csharp_default_private_modifier = implicit
resharper_csharp_default_internal_modifier = implicit
resharper_csharp_default_value_when_type_evident = default_literal
resharper_csharp_default_value_when_type_not_evident = default_literal
resharper_csharp_can_use_global_alias = false
resharper_csharp_force_attribute_style = separate
resharper_csharp_add_imports_to_deepest_scope = false
resharper_csharp_allow_alias = true
resharper_csharp_builtin_type_reference_style = use_keyword
resharper_csharp_builtin_type_reference_for_member_access_style = use_keyword
resharper_csharp_builtin_type_apply_to_native_integer = true
resharper_csharp_instance_members_qualify_members = none
resharper_csharp_instance_members_qualify_declared_in = this_class

# --- var usage: prefer var but do not change explicit types in cleanupcode ---
resharper_csharp_for_built_in_types = use_var
resharper_csharp_for_simple_types = use_var
resharper_csharp_for_other_types = use_var
resharper_suggest_var_or_type_built_in_types_highlighting = none
resharper_suggest_var_or_type_simple_types_highlighting = none
resharper_suggest_var_or_type_elsewhere_highlighting = none

# --- Using directives: do NOT optimize/shorten (handled via DotSettings) ---
resharper_csharp_qualified_using_at_nested_scope = false

# --- Member reordering: disabled ---
resharper_csharp_keep_existing_declaration_block_arrangement = true

# --- XML doc comment formatting: do not add extra indentation ---
resharper_xmldoc_indent_text = zero_indent

# --- Chain wrapping: prevent chain wrapping after initializer braces ---
resharper_csharp_wrap_after_property_in_chained_method_calls = false
resharper_csharp_wrap_chained_method_calls = wrap_if_long

# --- Indentation: match Roslyn IDE0055 expectations ---
resharper_csharp_indent_anonymous_method_block = false
resharper_csharp_indent_pars = inside
resharper_csharp_use_continuous_indent_inside_initializer_braces = false
resharper_csharp_stick_comment = false
resharper_csharp_indent_raw_literal_string = do_not_change
resharper_csharp_indent_nested_usings_stmt = false
resharper_csharp_indent_nested_for_stmt = false
resharper_csharp_indent_nested_foreach_stmt = false
resharper_csharp_indent_nested_while_stmt = false
resharper_csharp_indent_nested_lock_stmt = false
resharper_csharp_indent_nested_fixed_stmt = false
resharper_csharp_indent_method_decl_pars = inside
resharper_csharp_indent_invocation_pars = inside
resharper_csharp_indent_statement_pars = inside
resharper_csharp_indent_primary_constructor_decl_pars = inside
resharper_csharp_indent_typeparam_angles = inside
resharper_csharp_indent_typearg_angles = inside
resharper_csharp_indent_preprocessor_if = no_indent
resharper_csharp_indent_preprocessor_region = usual_indent
resharper_csharp_indent_preprocessor_other = no_indent
resharper_csharp_indent_type_constraints = true
resharper_csharp_indent_braces_inside_statement_conditions = false
resharper_csharp_alignment_tab_fill_style = use_spaces
resharper_csharp_allow_far_alignment = false
resharper_csharp_continuous_indent_multiplier = 1

# --- LINQ query alignment: align clauses with `from` keyword (matches Roslyn) ---
resharper_csharp_align_linq_query = true

# --- Multiline alignment: use continuous indent (matches Roslyn) ---
resharper_csharp_align_multiline_parameter = false
resharper_csharp_align_multiline_calls_chain = false
resharper_csharp_align_multiline_extends_list = false
resharper_csharp_align_multiline_argument = false
resharper_csharp_align_multiline_binary_expressions_chain = false
resharper_csharp_align_first_arg_by_paren = false
resharper_csharp_align_multiline_switch_expression = false
resharper_csharp_align_multiline_property_pattern = false
resharper_csharp_align_multiline_list_pattern = false
resharper_csharp_align_multiline_binary_patterns = false
resharper_csharp_align_tuple_components = false
resharper_csharp_align_multiline_expression = false
resharper_csharp_align_multiline_statement_conditions = false
resharper_csharp_align_multiline_for_stmt = true
resharper_csharp_align_multiple_declaration = false
resharper_csharp_align_multline_type_parameter_list = false
resharper_csharp_align_multline_type_parameter_constrains = false
resharper_csharp_align_multiline_comments = false
resharper_csharp_align_multiline_array_and_object_initializer = false
resharper_csharp_indent_switch_labels = true

# --- Column alignment: disabled ---
resharper_csharp_int_align_fields = false
resharper_csharp_int_align_properties = false
resharper_csharp_int_align_methods = false
resharper_csharp_int_align_parameters = false
resharper_csharp_int_align_variables = false
resharper_csharp_int_align_assignments = false
resharper_csharp_int_align_property_patterns = false
resharper_csharp_int_align_nested_ternary = false
resharper_csharp_int_align_invocations = false
resharper_csharp_int_align_binary_expressions = false
resharper_csharp_int_align_comments = false
resharper_csharp_int_align_switch_sections = false
resharper_csharp_int_align_switch_expressions = false
resharper_csharp_int_align_fix_in_adjacent = false

# --- Blank lines ---
resharper_csharp_keep_blank_lines_in_code = 1
resharper_csharp_keep_blank_lines_in_declarations = 1
resharper_csharp_blank_lines_after_using_list = 1
resharper_csharp_blank_lines_between_using_groups = 1
resharper_csharp_blank_lines_around_namespace = 1
resharper_csharp_blank_lines_inside_namespace = 1
resharper_csharp_blank_lines_after_file_scoped_namespace_directive = 1
resharper_csharp_blank_lines_around_type = 1
resharper_csharp_blank_lines_around_single_line_type = 1
resharper_csharp_blank_lines_inside_type = 0
resharper_csharp_blank_lines_around_field = 1
resharper_csharp_blank_lines_around_single_line_field = 0
resharper_csharp_blank_lines_around_property = 1
resharper_csharp_blank_lines_around_single_line_property = 0
resharper_csharp_blank_lines_around_auto_property = 1
resharper_csharp_blank_lines_around_single_line_auto_property = 0
resharper_csharp_blank_lines_around_accessor = 1
resharper_csharp_blank_lines_around_single_line_accessor = 0
resharper_csharp_blank_lines_around_invocable = 1
resharper_csharp_blank_lines_around_single_line_invocable = 0
resharper_csharp_blank_lines_around_local_method = 1
resharper_csharp_blank_lines_around_single_line_local_method = 0
resharper_csharp_blank_lines_around_region = 1
resharper_csharp_blank_lines_inside_region = 1
resharper_csharp_blank_lines_before_single_line_comment = 0
resharper_csharp_blank_lines_after_start_comment = 1
resharper_csharp_blank_lines_before_control_transfer_statements = 0
resharper_csharp_blank_lines_after_control_transfer_statements = 1
resharper_csharp_blank_lines_before_block_statements = 0
resharper_csharp_blank_lines_after_block_statements = 1
resharper_csharp_blank_lines_before_multiline_statements = 0
resharper_csharp_blank_lines_after_multiline_statements = 1
resharper_csharp_blank_lines_around_block_case_section = 1
resharper_csharp_blank_lines_around_multiline_case_section = 1
resharper_csharp_blank_lines_before_case = 1
resharper_csharp_blank_lines_after_case = 0

# --- Wrapping: high max line length prevents unwanted wrapping ---
resharper_csharp_max_line_length = 250
resharper_csharp_max_formal_parameters_on_line = 3
resharper_csharp_max_invocation_arguments_on_line = 3
resharper_csharp_max_primary_constructor_parameters_on_line = 3
resharper_csharp_max_initializer_elements_on_line = 1
resharper_csharp_max_array_initializer_elements_on_line = 1
resharper_csharp_max_enum_members_on_line = 1
resharper_csharp_max_attribute_length_for_same_line = 0
resharper_csharp_wrap_object_and_collection_initializer_style = chop_always
resharper_csharp_place_simple_initializer_on_single_line = false
resharper_csharp_keep_existing_expr_member_arrangement = true
resharper_csharp_keep_existing_attribute_arrangement = false
resharper_csharp_keep_existing_arrangement = true
resharper_csharp_keep_existing_initializer_arrangement = false
resharper_csharp_keep_existing_linebreaks = true
resharper_csharp_keep_existing_enum_arrangement = false
resharper_csharp_keep_existing_embedded_arrangement = false
resharper_csharp_keep_existing_embedded_block_arrangement = false
resharper_csharp_keep_existing_switch_expression_arrangement = false
resharper_csharp_keep_existing_property_patterns_arrangement = true
resharper_csharp_keep_existing_list_patterns_arrangement = false
resharper_csharp_keep_existing_invocation_parens_arrangement = true
resharper_csharp_keep_existing_declaration_parens_arrangement = true
resharper_csharp_keep_existing_primary_constructor_declaration_parens_arrangement = true
resharper_csharp_keep_user_linebreaks = true

# --- Wrap styles ---
resharper_csharp_wrap_parameters_style = chop_if_long
resharper_csharp_wrap_primary_constructor_parameters_style = chop_if_long
resharper_csharp_wrap_arguments_style = chop_if_long
resharper_csharp_wrap_extends_list_style = wrap_if_long
resharper_csharp_wrap_enum_declaration = chop_always
resharper_csharp_wrap_switch_expression = chop_always
resharper_csharp_wrap_chained_binary_expressions = chop_if_long
resharper_csharp_wrap_chained_binary_patterns = chop_if_long
resharper_csharp_wrap_ternary_expr_style = chop_if_long
resharper_csharp_wrap_linq_expressions = chop_if_long
resharper_csharp_wrap_array_initializer_style = chop_always
resharper_csharp_wrap_property_pattern = chop_if_long
resharper_csharp_wrap_list_pattern = chop_always
resharper_csharp_wrap_multiple_declaration_style = chop_if_long
resharper_csharp_wrap_multiple_type_parameter_constraints_style = chop_if_long
resharper_csharp_wrap_for_stmt_header_style = chop_if_long

# --- Wrap before/after ---
resharper_csharp_wrap_before_declaration_lpar = false
resharper_csharp_wrap_after_declaration_lpar = false
resharper_csharp_wrap_before_declaration_rpar = false
resharper_csharp_wrap_before_invocation_lpar = false
resharper_csharp_wrap_after_invocation_lpar = true
resharper_csharp_wrap_before_invocation_rpar = false
resharper_csharp_wrap_before_comma = false
resharper_csharp_wrap_before_eq = false
resharper_csharp_wrap_before_arrow_with_expressions = false
resharper_csharp_wrap_before_binary_opsign = false
resharper_csharp_wrap_before_binary_pattern_op = false
resharper_csharp_wrap_before_ternary_opsigns = false
resharper_csharp_wrap_before_extends_colon = false
resharper_csharp_wrap_before_type_parameter_langle = false
resharper_csharp_wrap_before_first_type_parameter_constraint = true
resharper_csharp_wrap_before_linq_expression = true
resharper_csharp_wrap_before_first_method_call = true
resharper_csharp_wrap_after_dot_in_method_calls = false
resharper_csharp_wrap_before_primary_constructor_declaration_lpar = false
resharper_csharp_wrap_after_primary_constructor_declaration_lpar = false
resharper_csharp_wrap_before_primary_constructor_declaration_rpar = false

# --- Force chop ---
resharper_csharp_force_chop_compound_if_expression = false
resharper_csharp_force_chop_compound_while_expression = false
resharper_csharp_force_chop_compound_do_expression = false

# --- Placement ---
resharper_csharp_place_constructor_initializer_on_same_line = true
resharper_csharp_place_type_constraints_on_same_line = false
resharper_csharp_place_expr_method_on_single_line = if_owner_is_single_line
resharper_csharp_place_expr_property_on_single_line = if_owner_is_single_line
resharper_csharp_place_expr_accessor_on_single_line = if_owner_is_single_line
resharper_csharp_place_simple_accessor_on_single_line = true
resharper_csharp_place_simple_accessorholder_on_single_line = true
resharper_csharp_place_abstract_accessorholder_on_single_line = true
resharper_csharp_place_simple_method_on_single_line = false
resharper_csharp_place_simple_embedded_statement_on_same_line = never
resharper_csharp_place_simple_case_statement_on_same_line = never
resharper_csharp_place_simple_enum_on_single_line = false
resharper_csharp_place_simple_switch_expression_on_single_line = false
resharper_csharp_place_simple_property_pattern_on_single_line = true
resharper_csharp_place_simple_list_pattern_on_single_line = true
resharper_csharp_place_simple_anonymousmethod_on_single_line = true
resharper_csharp_place_simple_embedded_block_on_same_line = false
resharper_csharp_place_linq_into_on_new_line = false
resharper_csharp_special_else_if_treatment = true
resharper_csharp_new_line_before_while = true
resharper_csharp_new_line_before_else = true
resharper_csharp_new_line_before_catch = true
resharper_csharp_new_line_before_finally = true
resharper_csharp_insert_final_newline = true
resharper_csharp_nested_ternary_style = autodetect
resharper_csharp_wrap_verbatim_interpolated_strings = no_wrap
resharper_csharp_place_accessor_with_attrs_holder_on_single_line = true

# --- Attribute placement ---
resharper_csharp_place_accessorholder_attribute_on_same_line = never
resharper_csharp_place_accessor_attribute_on_same_line = never
resharper_csharp_place_field_attribute_on_same_line = never
resharper_csharp_place_record_field_attribute_on_same_line = never
resharper_csharp_place_method_attribute_on_same_line = never
resharper_csharp_place_type_attribute_on_same_line = never


# HTML files
[*.{html,htm,cshtml,razor}]
resharper_html_attribute_style = do_not_touch
resharper_html_attribute_indent = align_by_first_attribute
resharper_html_sort_attributes = false
resharper_html_sort_class_selectors = false
resharper_html_spaces_around_eq_in_attribute = false
resharper_html_space_before_self_closing = true
resharper_html_max_blank_lines_between_tags = 1
resharper_html_linebreak_before_multiline_elements = true
resharper_html_extra_spaces = remove_all
resharper_html_blank_line_after_pi = true
resharper_html_alignment_tab_fill_style = use_spaces
resharper_html_allow_far_alignment = false
resharper_html_space_after_last_attribute = true
resharper_html_linebreak_before_all_elements = false
resharper_html_linebreaks_inside_tags_for_multiline_elements = true
resharper_html_linebreaks_inside_tags_for_elements_with_child_elements = true
resharper_html_no_indent_inside_if_element_longer_than = 0
resharper_html_pi_attribute_style = do_not_touch
resharper_html_pi_attributes_indent = single_indent
resharper_html_spaces_around_eq_in_pi_attribute = false
resharper_html_space_after_last_pi_attribute = false

# Razor files
[*.{razor,cshtml}]
csharp_preserve_single_line_statements = false
csharp_preserve_single_line_blocks = true
resharper_csharp_wrap_object_and_collection_initializer_style = chop_always
resharper_csharp_place_simple_initializer_on_single_line = false
resharper_csharp_place_accessorholder_attribute_on_same_line = never
resharper_csharp_place_field_attribute_on_same_line = never
resharper_csharp_place_method_attribute_on_same_line = never
resharper_csharp_place_type_attribute_on_same_line = never
resharper_csharp_keep_existing_attribute_arrangement = false
resharper_csharp_keep_existing_arrangement = true
resharper_razor_always_use_end_of_line_brace_style = false
resharper_html_blank_lines_around_razor_functions = 1
resharper_html_blank_lines_around_razor_sections = 1
resharper_html_blank_lines_around_razor_helpers = 1

dotnet_diagnostic.S3881.severity = none
dotnet_diagnostic.MA0046.severity = none

# Migration files (discovered via reflection by MongoFlow)
[**/Migrations/*.cs]
dotnet_diagnostic.MA0182.severity = none

# Generated files
[*.{generated,g,g.i,g.cs}.cs]
generated_code = true
dotnet_analyzer_diagnostic.severity = none

# Verify
[*.{received,verified}.{txt}]
charset = utf-8-bom
end_of_line = lf
indent_size = unset
indent_style = unset
insert_final_newline = false
tab_width = unset
trim_trailing_whitespace = false

